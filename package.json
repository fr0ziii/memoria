{
  "name": "@fr0ziii/pi-memoria",
  "version": "0.1.0",
  "description": "BM25 search for Obsidian vaults — agent memory system for Pi",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "memoria": "./dist/index.js"
  },
  "files": [
    "dist/",
    "SKILL.md",
    "src/",
    "LICENSE.md",
    "README.md"
  ],
  "keywords": [
    "pi-package",
    "obsidian",
    "bm25",
    "search",
    "vault",
    "pi-skill",
    "agent-memory"
  ],
  "pi": {
    "skills": [
      "./"
    ]
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "dev": "bun run src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "minisearch": "^7.2.0"
  },
  "bundledDependencies": [
    "minisearch"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
